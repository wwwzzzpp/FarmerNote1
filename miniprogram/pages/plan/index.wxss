.plan-card {
  gap: 14rpx;
}

.plan-meta-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 24rpx;
  margin-top: 24rpx;
}

.plan-meta-cell {
  padding: 20rpx 24rpx;
  border-radius: 28rpx;
  background: #f5f0e4;
  border: 2rpx solid #e1d7be;
}

.plan-meta-label {
  display: block;
  font-size: 24rpx;
  color: #7a735f;
}

.plan-meta-value {
  display: block;
  margin-top: 10rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #4c4737;
}

.plan-focus-card {
  margin-top: 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 28rpx;
  background: #e7e0cf;
  border: 2rpx solid #d4c7a7;
}

.plan-focus-label {
  display: block;
  font-size: 24rpx;
  color: #706955;
}

.plan-focus-title {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #3f3a2c;
}

.plan-focus-caption {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #6a6451;
}

.plan-picker-grid {
  margin-top: 20rpx;
}

.plan-picker-field {
  width: 100%;
}
