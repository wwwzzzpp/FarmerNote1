.plan-stage-card--current {
  border-color: #d9c37f;
}

.plan-stage-card--passed {
  border-color: #abc39d;
}

.plan-stage-card--upcoming {
  border-color: #d9cfb7;
}

.plan-milestone-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: #f6f1e6;
  border: 2rpx solid #e1d7bf;
}

.plan-milestone-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #4a4434;
}

.plan-milestone-progress {
  font-size: 24rpx;
  color: #6f6854;
  font-weight: 700;
}

.plan-action-row {
  display: flex;
  gap: 18rpx;
  align-items: flex-start;
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid #e8dfca;
}

.plan-action-row:first-of-type {
  border-top: none;
  padding-top: 0;
}

.plan-action-main {
  flex: 1;
}

.plan-action-side {
  width: 180rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 14rpx;
}

.plan-action-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #3f392b;
}

.plan-action-button {
  width: 100%;
}

.plan-recent-entry {
  margin-top: 14rpx;
  padding: 16rpx 18rpx;
  border-radius: 24rpx;
  background: #ebe4d2;
}

.plan-recent-entry-label {
  display: block;
  font-size: 22rpx;
  color: #736c58;
}

.plan-recent-entry-text {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #504a3a;
}
