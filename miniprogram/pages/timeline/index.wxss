.hero-strip {
  position: relative;
}

.timeline-day-group {
  position: relative;
  margin-top: 28rpx;
  padding: 22rpx 20rpx 12rpx;
  border-radius: 28rpx;
  background: #e7e0cf;
  border: 1px solid #d0c5ab;
}

.timeline-day-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding-left: 10rpx;
}

.timeline-day-label {
  position: relative;
  flex: 1;
  min-width: 0;
  padding-left: 22rpx;
}

.timeline-day-label::before {
  content: "";
  position: absolute;
  left: 0;
  top: 10rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #7a805d;
  box-shadow: none;
}

.timeline-day-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #4d4938;
}

.timeline-day-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 23rpx;
  color: #756f5d;
}

.timeline-day-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #f4f0e6;
  border: 1px solid #d9cfb8;
  font-size: 22rpx;
  font-weight: 700;
  color: #635d49;
}

.timeline-thread {
  position: relative;
  margin-top: 18rpx;
  padding-left: 12rpx;
}

.timeline-thread::before {
  content: "";
  position: absolute;
  left: 29rpx;
  top: 12rpx;
  bottom: 18rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: #c4baa0;
}

.timeline-thread-item {
  position: relative;
  display: flex;
  align-items: stretch;
  gap: 22rpx;
  margin-top: 18rpx;
}

.timeline-thread-item:first-child {
  margin-top: 0;
}

.timeline-rail {
  position: relative;
  width: 36rpx;
  flex: 0 0 36rpx;
}

.thread-dot {
  position: absolute;
  left: 6rpx;
  top: 24rpx;
  width: 22rpx;
  height: 22rpx;
  border-radius: 999rpx;
  border: 5rpx solid #ffffff;
  box-shadow: none;
  z-index: 2;
}

.thread-dot--neutral {
  background: #bfb8a5;
}

.thread-dot--warning {
  background: #efc767;
}

.thread-dot--danger {
  background: #e59898;
}

.thread-dot--success {
  background: #96a076;
}

.thread-line {
  display: none;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  min-height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #efe8d8;
  color: #5f5843;
  font-size: 22rpx;
  font-weight: 700;
}

.timeline-card {
  border: 1px solid transparent;
  margin-top: 0;
  width: 100%;
}

.timeline-card--focused {
  border-color: #b7ad8c;
  box-shadow: none;
}

.timeline-time {
  font-size: 30rpx;
}

.timeline-body {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  line-height: 1.7;
  color: #111827;
  white-space: pre-wrap;
}

.timeline-photo-thumb {
  display: block;
  width: 220rpx;
  height: 164rpx;
  margin-top: 18rpx;
  border-radius: 18rpx;
  background: #ddd5c2;
}
