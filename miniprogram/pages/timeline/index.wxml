<view class="app-shell">
  <view class="section-card hero-card hero-strip">
    <text class="hero-kicker">TIMELINE</text>
    <text class="hero-title">巡田时间线</text>
    <text class="hero-body">所有记录都按时间倒序排好，带提醒的记录会直接显示当前处理状态。</text>
    <text class="hero-badge">共 {{entryCount}} 条</text>
  </view>

  <view wx:if="{{isEmpty}}" class="section-card empty-state">
    <text class="empty-title">时间线还是空的</text>
    <text class="empty-body">先去“记录”页写下第一条巡田观察，这里就会自动出现。</text>
  </view>

  <block wx:for="{{entries}}" wx:key="id">
    <view class="section-card timeline-card {{item.focusClass}}">
      <view class="section-heading">
        <view class="section-heading-main">
          <text class="section-title timeline-time">{{item.createdLabel}}</text>
          <text class="section-subtitle">更新时间：{{item.updatedLabel}}</text>
        </view>
        <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
      </view>

      <text class="timeline-body">{{item.noteText}}</text>

      <view wx:if="{{item.hasTask}}" class="timeline-meta">
        <view class="meta-row">
          <text class="meta-label">提醒时间</text>
          <text class="meta-value">{{item.taskDueLabel}}</text>
        </view>
        <text class="meta-full">完整时间：{{item.taskDueFullLabel}}</text>
      </view>

      <view class="action-row action-row--pair">
        <button
          wx:if="{{item.hasTask}}"
          class="action-button secondary-button small-button"
          data-task-id="{{item.taskId}}"
          bindtap="openTask"
        >
          打开待办
        </button>
        <button
          class="action-button danger-button small-button"
          data-entry-id="{{item.id}}"
          data-has-task="{{item.hasTask}}"
          bindtap="deleteEntry"
        >
          删除记录
        </button>
      </view>
    </view>
  </block>

  <view class="nav-bar">
    <button class="nav-item" bindtap="goRecord">记录</button>
    <button class="nav-item nav-item--active" bindtap="goTimeline">时间线</button>
    <button class="nav-item" bindtap="goTasks">待办</button>
  </view>
</view>
