<view class="app-shell">
  <view class="section-card hero-card hero-strip">
    <text class="hero-kicker">TIMELINE</text>
    <text class="hero-title">巡田时间线</text>
    <text class="hero-badge">共 {{entryCount}} 条</text>
  </view>

  <view wx:if="{{isInitialLoading}}" class="section-card loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-title">正在加载时间线…</text>
    <text class="loading-body">先把本机和云端记录对齐，请稍等。</text>
  </view>

  <view wx:elif="{{isEmpty}}" class="section-card empty-state">
    <text class="empty-title">时间线还是空的</text>
    <text class="empty-body">先去“记录”页写下第一条巡田观察，这里就会自动出现。</text>
  </view>

  <block wx:for="{{dayGroups}}" wx:key="dayKey" wx:for-item="group">
    <view class="timeline-day-group">
      <view class="timeline-day-header">
        <view class="timeline-day-label">
          <text class="timeline-day-title">{{group.dayLabel}}</text>
          <text class="timeline-day-caption">{{group.dayCaption}}</text>
        </view>
        <text class="timeline-day-count">{{group.countLabel}}</text>
      </view>

      <view class="timeline-thread">
        <block wx:for="{{group.entries}}" wx:key="id" wx:for-item="entry">
          <view class="timeline-thread-item">
            <view class="timeline-rail">
              <view class="thread-dot {{entry.dotClass}}"></view>
              <view wx:if="{{!entry.isLastInGroup}}" class="thread-line"></view>
            </view>

            <view class="section-card timeline-card {{entry.focusClass}}">
              <view class="section-heading">
                <view class="section-heading-main">
                  <text class="section-title timeline-time">{{entry.createdClockLabel}}</text>
                </view>
                <text class="status-chip {{entry.statusClass}}">{{entry.statusLabel}}</text>
              </view>

              <text class="timeline-body">{{entry.noteText}}</text>

              <image
                wx:if="{{entry.hasPhoto}}"
                class="timeline-photo-thumb"
                src="{{entry.photoPath}}"
                mode="aspectFill"
                data-photo-path="{{entry.photoPath}}"
                bindtap="previewPhoto"
              />

              <view class="action-row action-row--pair">
                <button
                  wx:if="{{entry.hasTask}}"
                  class="action-button secondary-button small-button"
                  data-task-id="{{entry.taskId}}"
                  bindtap="openTask"
                >
                  打开待办
                </button>
                <button
                  class="action-button danger-button small-button"
                  data-entry-id="{{entry.id}}"
                  data-has-task="{{entry.hasTask}}"
                  bindtap="deleteEntry"
                >
                  删除记录
                </button>
              </view>
            </view>
          </view>
        </block>
      </view>
    </view>
  </block>

  <view class="nav-bar">
    <button class="nav-item" bindtap="goRecord">记录</button>
    <button class="nav-item nav-item--active" bindtap="goTimeline">时间线</button>
    <button class="nav-item" bindtap="goTasks">待办</button>
    <button class="nav-item" bindtap="goMe">我</button>
  </view>
</view>
