.note-composer {
  margin-top: 22rpx;
  border-radius: 24rpx;
  border: 1px solid #d6ccb5;
  background: #f3efe4;
  padding: 20rpx;
}

.textarea--compact {
  margin-top: 0;
  min-height: 0;
  height: 112rpx;
  padding: 0;
  border: 0;
  background: transparent;
  line-height: 56rpx;
}

.composer-photo-wrap {
  margin-top: 18rpx;
}

.composer-photo-thumb {
  display: block;
  width: 100%;
  height: 220rpx;
  border-radius: 20rpx;
  background: #e6decd;
}

.composer-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 18rpx;
}

.composer-tools {
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 0;
}

.camera-button,
.remove-photo-button {
  min-height: 64rpx;
  border-radius: 18rpx;
  padding: 0 22rpx;
  font-size: 24rpx;
}

.camera-button {
  border: 1px solid #cfc5aa;
  background: #e5dfcd;
  color: #4f573b;
}

.remove-photo-button {
  border: 1px solid #ddd4c2;
  background: #f1ece1;
  color: #6b6656;
}

.composer-save-button {
  min-width: 228rpx;
  min-height: 68rpx;
  border-radius: 18rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.photo-hint {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #756f61;
}

.cloud-sync-button {
  width: 240rpx;
  margin-top: 20rpx;
}
