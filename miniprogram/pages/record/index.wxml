<view class="app-shell">
  <view class="section-card hero-card">
    <text class="hero-kicker">FARMER NOTE</text>
    <text class="hero-title">今天田里看到啥，先记下来。</text>
    <!-- <text class="hero-body">记录会自动串成时间线。带提醒的记录会同步变成一条待办，方便后面继续跟。</text> -->

    <view class="stats-row">
      <view class="stat-card">
        <text class="stat-value">{{stats.entryCount}}</text>
        <text class="stat-label">总记录</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.pendingTaskCount}}</text>
        <text class="stat-label">待办中</text>
      </view>
      <view class="stat-card">
        <text class="stat-value">{{stats.overdueTaskCount}}</text>
        <text class="stat-label">已逾期</text>
      </view>
    </view>
  </view>

  <view wx:if="{{draftSourceLabel}}" class="section-card muted-card">
    <text class="preview-label">当前来自作物计划</text>
    <text class="preview-time">{{draftSourceLabel}}</text>
    <text class="helper-text">保存后，这条记录会和对应的小动作关联起来，后面可以在计划详情里回看。</text>
  </view>

  <view wx:if="{{!cloudStatus.isSignedIn}}" class="section-card">
    <text class="section-title">{{cloudStatus.headline}}</text>
    <text class="helper-text">{{cloudStatus.detail}}</text>
    <view wx:if="{{cloudStatus.shouldShowPrimaryAction || cloudStatus.canLinkWeChat}}" class="cloud-auth-actions">
      <button
        wx:if="{{cloudStatus.shouldShowPrimaryAction}}"
        class="action-button primary-button small-button cloud-sync-button"
        bindtap="handleCloudPrimaryAction"
        loading="{{cloudStatus.isBusy}}"
        disabled="{{!cloudStatus.isConfigured}}"
      >
        {{cloudStatus.primaryActionLabel || cloudStatus.actionLabel}}
      </button>
      <button
        wx:if="{{cloudStatus.canLinkWeChat}}"
        class="action-button ghost-button small-button cloud-secondary-button"
        bindtap="handleLinkWeChatAction"
        disabled="{{!cloudStatus.isConfigured || phoneActionBusy}}"
      >
        绑定微信
      </button>
    </view>

    <view wx:if="{{cloudStatus.secondaryActionLabel || cloudStatus.canLinkPhone}}" class="cloud-phone-panel">
      <input
        class="cloud-input"
        type="number"
        placeholder="输入中国大陆手机号，例如 13800138000"
        value="{{phoneNumber}}"
        bindinput="handlePhoneNumberInput"
      />
      <view class="cloud-code-row">
        <input
          class="cloud-input cloud-input--code"
          type="number"
          maxlength="6"
          placeholder="输入验证码"
          value="{{phoneCode}}"
          bindinput="handlePhoneCodeInput"
        />
        <button
          class="action-button ghost-button small-button cloud-code-button"
          bindtap="handleSendPhoneCode"
          disabled="{{!cloudStatus.isConfigured || phoneActionBusy || phoneCodeCountdown > 0}}"
        >
          {{phoneCodeCountdown > 0 ? phoneCodeCountdown + ' 秒后重发' : '发送验证码'}}
        </button>
      </view>
      <button
        class="action-button secondary-button small-button cloud-submit-button"
        bindtap="handleCloudPhoneAction"
        disabled="{{!cloudStatus.isConfigured || phoneActionBusy}}"
        loading="{{phoneActionBusy}}"
      >
        {{cloudStatus.canLinkPhone ? '绑定手机号' : '手机号验证码登录'}}
      </button>
    </view>
  </view>

  <view class="section-card">
    <view class="section-heading">
      <view class="section-heading-main">
        <text class="toggle-caption">提示词中可以包含：提醒我、提醒一下、提醒下、记得、别忘、定时、到时、到时候、闹钟。</text>
      </view>
    </view>
    <view class="note-composer">
      <textarea
        class="textarea textarea--compact"
        placeholder="提醒我东南角麦苗偏黄，沟边有积水。下午三点再去补看。"
        value="{{noteText}}"
        bindinput="handleNoteInput"
        bindlinechange="handleNoteLineChange"
        maxlength="-1"
      />

      <view wx:if="{{photoTempPath}}" class="composer-photo-wrap">
        <image class="composer-photo-thumb" src="{{photoTempPath}}" mode="aspectFill" bindtap="previewPhoto" />
        <text class="photo-hint">已附带现场照片，点图可放大查看。</text>
      </view>

      <view class="composer-footer">
        <view class="composer-tools">
          <button class="action-button camera-button" bindtap="handleTakePhoto">
            {{photoTempPath ? '重拍照片' : '拍照记录'}}
          </button>
          <button wx:if="{{photoTempPath}}" class="action-button remove-photo-button" bindtap="clearPhoto">
            删除照片
          </button>
        </view>
        <button class="action-button primary-button composer-save-button" bindtap="handleSave" loading="{{isSaving}}">
          保存这条记录
        </button>
      </view>
    </view>

    <view class="toggle-row">
      <view class="toggle-main">
        <text class="toggle-label">需要定时处理吗？</text>
      </view>
      <switch checked="{{reminderEnabled}}" color="#6f7751" bindchange="handleReminderToggle" />
    </view>

    <view wx:if="{{smartReminderVisible}}" class="smart-detect-card">
      <view class="section-heading">
        <view class="section-heading-main">
          <text class="smart-detect-title">系统识别到定时处理</text>
          <text class="smart-detect-body">{{smartReminderMessage}}</text>
        </view>
        <text class="status-chip {{smartReminderToneClass}}">{{smartReminderTag}}</text>
      </view>
      <text wx:if="{{smartReminderMatchedText}}" class="smart-detect-hit">命中内容：{{smartReminderMatchedText}}</text>
    </view>

    <view wx:if="{{reminderEnabled}}" class="picker-grid">
      <view class="picker-field">
        <text class="picker-label">日期</text>
        <picker mode="date" value="{{reminderDate}}" bindchange="handleDateChange">
          <view class="picker-value">{{reminderDate}}</view>
        </picker>
      </view>

      <view class="picker-field">
        <text class="picker-label">时间</text>
        <picker mode="time" value="{{reminderTime}}" bindchange="handleTimeChange">
          <view class="picker-value">{{reminderTime}}</view>
        </picker>
      </view>

      <text class="helper-text">保存后会自动尝试把这条任务写入手机系统日历。如果当前微信环境或权限不支持，记录本身仍会正常保存。</text>
    </view>
  </view>

  <view wx:if="{{previewTimeText}}" class="section-card muted-card">
    <text class="preview-label">这条提醒会出现在待办里</text>
    <text class="preview-time">{{previewTimeText}}</text>
    <text class="helper-text">{{previewHint}}</text>
  </view>

  <view wx:if="{{feedbackMessage}}" class="section-card success-card">
    <text class="section-title">刚刚保存成功</text>
    <text class="helper-text">{{feedbackMessage}}</text>
  </view>

  <view class="section-card">
    <view class="section-heading">
      <view class="section-heading-main">
        <text class="section-title">待办模块</text>
        <text class="helper-text">你设置过时间的记录，会汇总到这里，写完记录后可以顺手继续处理。</text>
        <text wx:if="{{taskModule.hasTasks}}" class="helper-text">已显示 {{taskModule.visibleCount}} / {{taskModule.totalCount}} 条</text>
      </view>
    </view>
  </view>

  <view wx:if="{{taskModule.isInitialLoading}}" class="section-card loading-state">
    <view class="loading-spinner"></view>
    <text class="loading-title">正在加载待办…</text>
    <text class="loading-body">先把本机和云端提醒对齐，请稍等。</text>
  </view>

  <view wx:elif="{{!taskModule.hasTasks}}" class="section-card empty-state">
    <text class="empty-title">还没有定时任务</text>
    <text class="empty-body">在上面的记录框里打开提醒时间，这里就会自动接住。</text>
  </view>

  <view wx:if="{{taskModule.hasUpcomingTasks}}">
    <text class="section-block-title">即将到来</text>
    <text class="section-block-caption">未来的巡田动作</text>

    <block wx:for="{{taskModule.upcomingTasks}}" wx:key="id">
      <view class="section-card task-card {{item.focusClass}}">
        <view class="section-heading">
          <view class="section-heading-main">
            <text class="section-title task-due">{{item.dueLabel}}</text>
          </view>
          <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
        </view>

        <text class="task-note">{{item.noteText}}</text>
        <image
          wx:if="{{item.hasPhoto}}"
          class="task-photo-thumb"
          src="{{item.photoPath}}"
          mode="aspectFill"
          data-photo-path="{{item.photoPath}}"
          bindtap="previewTaskPhoto"
        />
        <view class="action-row action-row--pair task-action-grid">
          <button
            wx:if="{{item.canComplete}}"
            class="action-button primary-button small-button"
            data-task-id="{{item.id}}"
            bindtap="handleTaskComplete"
          >
            完成
          </button>
          <button
            class="action-button danger-button small-button"
            data-task-id="{{item.id}}"
            bindtap="handleTaskDelete"
          >
            删除任务
          </button>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{taskModule.hasOverdueTasks}}">
    <text class="section-block-title">已逾期</text>
    <text class="section-block-caption">时间到了但还没处理</text>

    <block wx:for="{{taskModule.overdueTasks}}" wx:key="id">
      <view class="section-card task-card {{item.focusClass}}">
        <view class="section-heading">
          <view class="section-heading-main">
            <text class="section-title task-due">{{item.dueLabel}}</text>
          </view>
          <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
        </view>

        <text class="task-note">{{item.noteText}}</text>
        <image
          wx:if="{{item.hasPhoto}}"
          class="task-photo-thumb"
          src="{{item.photoPath}}"
          mode="aspectFill"
          data-photo-path="{{item.photoPath}}"
          bindtap="previewTaskPhoto"
        />
        <view class="action-row action-row--pair task-action-grid">
          <button
            wx:if="{{item.canComplete}}"
            class="action-button primary-button small-button"
            data-task-id="{{item.id}}"
            bindtap="handleTaskComplete"
          >
            完成
          </button>
          <button
            class="action-button danger-button small-button"
            data-task-id="{{item.id}}"
            bindtap="handleTaskDelete"
          >
            删除任务
          </button>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{taskModule.hasCompletedTasks}}">
    <text class="section-block-title">已完成</text>
    <text class="section-block-caption">已经处理完的提醒</text>

    <block wx:for="{{taskModule.completedTasks}}" wx:key="id">
      <view class="section-card task-card {{item.focusClass}}">
        <view class="section-heading">
          <view class="section-heading-main">
            <text class="section-title task-due">{{item.dueLabel}}</text>
          </view>
          <text class="status-chip {{item.statusClass}}">{{item.statusLabel}}</text>
        </view>

        <text class="task-note">{{item.noteText}}</text>
        <image
          wx:if="{{item.hasPhoto}}"
          class="task-photo-thumb"
          src="{{item.photoPath}}"
          mode="aspectFill"
          data-photo-path="{{item.photoPath}}"
          bindtap="previewTaskPhoto"
        />
        <view class="action-row action-row--pair">
          <button
            class="action-button danger-button small-button"
            data-task-id="{{item.id}}"
            bindtap="handleTaskDelete"
          >
            删除任务
          </button>
        </view>
      </view>
    </block>
  </view>

  <view wx:if="{{taskModule.hasMore}}" class="section-card muted-card">
    <text class="preview-label">待办还没看完</text>
    <text class="helper-text">继续上滑会自动加载更多，你也可以点下面按钮继续展开。</text>
    <view class="action-row action-row--single">
      <button class="action-button ghost-button small-button" bindtap="loadMoreTaskModule">
        {{taskModule.loadMoreLabel || '加载更多'}}
      </button>
    </view>
  </view>

  <!-- <view class="section-card info-card">
    <text class="section-title">下一步</text>
    <text class="helper-text">时间线会展示所有历史记录，记录页底部的待办模块会把挂了时间的记录自动分成即将到来、已逾期和已完成。</text>

    <view class="action-row action-row--pair">
      <button class="action-button secondary-button small-button" bindtap="goTimeline">查看时间线</button>
      <button class="action-button ghost-button small-button" bindtap="goRecord">回到记录</button>
    </view>
  </view> -->

  <view class="nav-bar">
    <button class="nav-item nav-item--active" bindtap="goRecord">记录</button>
    <button class="nav-item" bindtap="goPlan">计划</button>
    <button class="nav-item" bindtap="goTimeline">时间线</button>
    <button class="nav-item" bindtap="goMe">我</button>
  </view>
</view>
