page {
  background: #efe9dd;
  color: #111827;
  font-family: "PingFang SC", "Helvetica Neue", Arial, sans-serif;
}

view,
text,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  line-height: 1.2;
  background: transparent;
}

button::after {
  border: 0;
}

.app-shell {
  min-height: 100vh;
  padding: 24rpx 24rpx 176rpx;
  background: #efe9dd;
}

.section-card {
  margin-top: 24rpx;
  border-radius: 28rpx;
  background: #f8f4ea;
  padding: 28rpx;
  border: 1px solid #d8cfba;
  box-shadow: 0 8rpx 18rpx rgba(96, 82, 58, 0.06);
}

.section-card:first-child {
  margin-top: 0;
}

.hero-card {
  background: #d9d1b8;
  border: 1px solid #c7bea4;
  color: #3d3a2f;
}

.hero-kicker {
  display: block;
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: #6d674f;
  opacity: 1;
}

.hero-title {
  display: block;
  margin-top: 16rpx;
  font-size: 48rpx;
  line-height: 1.25;
  font-weight: 700;
}

.hero-body {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.75;
  color: #5c5847;
}

.section-title {
  display: block;
  font-size: 32rpx;
  line-height: 1.4;
  font-weight: 700;
  color: #111827;
}

.section-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #746d5d;
}

.section-heading {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-heading-main {
  flex: 1;
  min-width: 0;
  padding-right: 16rpx;
}

.stats-row {
  display: flex;
  margin-top: 24rpx;
}

.stat-card {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  background: #e7e0ca;
  border: 1px solid #d0c6ab;
  padding: 16rpx 18rpx;
  margin-right: 16rpx;
}

.stat-card:last-child {
  margin-right: 0;
}

.stat-value {
  display: block;
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #504b38;
}

.stat-label {
  display: block;
  margin-left: 8rpx;
  font-size: 28rpx;
  line-height: 1.2;
  color: #6b654f;
}

.textarea {
  width: 100%;
  min-height: 260rpx;
  margin-top: 24rpx;
  border-radius: 24rpx;
  border: 1px solid #d6ccb5;
  background: #f3efe4;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
  color: #111827;
}

.helper-text {
  display: block;
  margin-top: 18rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #736d5e;
}

.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 28rpx;
}

.toggle-main {
  flex: 1;
  min-width: 0;
  padding-right: 20rpx;
}

.toggle-label {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.toggle-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #736d5e;
}

.picker-grid {
  margin-top: 24rpx;
}

.picker-field {
  margin-top: 16rpx;
}

.picker-field:first-child {
  margin-top: 0;
}

.picker-label {
  display: block;
  font-size: 24rpx;
  color: #736d5e;
}

.picker-value {
  margin-top: 10rpx;
  border-radius: 22rpx;
  border: 1px solid #d6ccb5;
  background: #f0ebdf;
  padding: 22rpx 24rpx;
  font-size: 30rpx;
  color: #111827;
}

.preview-label {
  display: block;
  font-size: 24rpx;
  color: #655f50;
}

.smart-detect-card {
  margin-top: 24rpx;
  border-radius: 22rpx;
  background: #ece6d6;
  padding: 22rpx 24rpx;
  border: 1px solid #d4c9af;
}

.smart-detect-title {
  display: block;
  font-size: 28rpx;
  line-height: 1.45;
  font-weight: 700;
  color: #4f4937;
}

.smart-detect-body {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.65;
  color: #655f50;
}

.smart-detect-hit {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #756f61;
}

.preview-time {
  display: block;
  margin-top: 12rpx;
  font-size: 42rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #111827;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 700;
  white-space: nowrap;
}

.status-chip--success {
  background: #e2e5d3;
  color: #5a6440;
}

.status-chip--warning {
  background: #f3e3b3;
  color: #8a6513;
}

.status-chip--danger {
  background: #ffe8e8;
  color: #b42318;
}

.status-chip--neutral {
  background: #ebe7da;
  color: #6a6554;
}

.action-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  font-weight: 700;
  text-align: center;
}

.small-button {
  min-height: 68rpx;
  border-radius: 18rpx;
  padding: 0 22rpx;
  font-size: 26rpx;
}

.primary-button {
  background: #6f7751;
  border: 1px solid #636a48;
  box-shadow: none;
  color: #ffffff;
}

.secondary-button {
  background: #e5dfcd;
  border: 1px solid #cfc5aa;
  color: #4f573b;
}

.ghost-button {
  background: #f1ece1;
  border: 1px solid #ddd4c2;
  color: #6b6656;
}

.danger-button {
  background: #f8ebeb;
  border: 1px solid #ebd2d2;
  color: #c23939;
}

.action-row {
  margin-top: 20rpx;
}

.action-row--single .action-button {
  width: 100%;
  margin-top: 0;
}

.action-row--pair {
  display: flex;
  flex-wrap: wrap;
  margin-left: -8rpx;
  margin-right: -8rpx;
}

.action-row--pair .action-button {
  flex: 1 1 0;
  min-width: 0;
  width: auto;
  margin-top: 16rpx;
  margin-left: 8rpx;
  margin-right: 8rpx;
}

.action-row--pair .action-button:only-child {
  flex-basis: 100%;
}

.action-row--stack .action-button {
  width: 100%;
  margin-top: 16rpx;
}

.action-row--stack .action-button:first-child {
  margin-top: 0;
}

.muted-card {
  background: #f2ede1;
}

.success-card {
  background: #ece6d6;
}

.info-card {
  background: #f4f0e7;
}

.empty-state {
  padding: 44rpx 24rpx;
  text-align: center;
}

.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 44rpx 24rpx;
  text-align: center;
}

.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border-radius: 999rpx;
  border: 6rpx solid #d6ccb5;
  border-top-color: #7a805d;
  animation: farmernote-spin 0.9s linear infinite;
}

.loading-title {
  display: block;
  margin-top: 20rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.loading-body {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #736d5e;
}

.empty-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #111827;
}

.empty-body {
  display: block;
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #736d5e;
}

.section-block-title {
  display: block;
  margin-top: 30rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #59533f;
}

.section-block-caption {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #736d5e;
}

@keyframes farmernote-spin {
  from {
    transform: rotate(0deg);
  }

  to {
    transform: rotate(360deg);
  }
}

.nav-bar {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-radius: 999rpx;
  background: #d4ccb5;
  border: 1px solid #c2b89b;
  box-shadow: none;
  z-index: 20;
}

.nav-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  border-radius: 999rpx;
  color: #625d4b;
  font-size: 26rpx;
  font-weight: 700;
}

.nav-item--active {
  background: #faf6ed;
  box-shadow: none;
  color: #383425;
}
