SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=key
FARMERNOTE_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

WECHAT_MINI_APP_ID= appid
WECHAT_MINI_APP_SECRET=appsecret

WECHAT_OPEN_APP_ID=wx_your_open_platform_app_id
WECHAT_OPEN_APP_SECRET=your-open-platform-app-secret

FARMERNOTE_ACCESS_TOKEN_TTL_SECONDS=86400
FARMERNOTE_REFRESH_TOKEN_TTL_SECONDS=2592000
FARMERNOTE_ACCOUNT_DELETION_WINDOW_DAYS=15
FARMERNOTE_ACCOUNT_PURGE_TOKEN=replace-with-an-admin-purge-token
FARMERNOTE_USER_RATE_LIMIT_PER_MINUTE=30
FARMERNOTE_IP_RATE_LIMIT_PER_MINUTE=30
FARMERNOTE_ENABLE_DEV_LOGIN=false
FARMERNOTE_DEV_LOGIN_KEY=farmernote-local-shared-user
FARMERNOTE_PHONE_CODE_SECRET=replace-with-a-long-random-secret
FARMERNOTE_PHONE_OTP_LENGTH=6
FARMERNOTE_PHONE_OTP_TTL_SECONDS=300
FARMERNOTE_PHONE_OTP_RESEND_COOLDOWN_SECONDS=60
FARMERNOTE_PHONE_OTP_MAX_ATTEMPTS=5
ALIYUN_SMS_ACCESS_KEY_ID=your-aliyun-access-key-id
ALIYUN_SMS_ACCESS_KEY_SECRET=your-aliyun-access-key-secret
ALIYUN_SMS_SIGN_NAME=your-approved-sign-name
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789
ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com
